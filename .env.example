# Copy this file to .env.development for local dev, or let CI generate
# .env.production / .env.staging from GitHub Secrets at build time.
#
# All VITE_* vars are BUNDLED INTO THE CLIENT. Anything put here ships to
# every user and is visible in the packaged app — only use for public/build-time
# keys (Aptabase app key, public API endpoints). True secrets must stay
# server-side behind an API.

# Rooms/WebSocket backend for this environment
VITE_ROOMS_SERVER_URL=

# Aptabase Analytics (https://aptabase.com)
# App key from the Aptabase dashboard. Leave empty to disable telemetry entirely.
VITE_APTABASE_APP_KEY=
# Optional: self-hosted Aptabase instance. Leave empty to use Aptabase Cloud.
VITE_APTABASE_HOST=
