{
  "name": "lol-skin-picker",
  "productName": "Skin Picker",
  "private": false,
  "author": "Valentin Dumas <valentin3135@gmail.com>",
  "version": "7.3.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nano315/lol-skin-picker.git"
  },
  "description": "Petite application Electron qui choisit et applique aleatoirement un skin (et chroma) pendant la phase de selection de champion sur League of Legends.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder --config electron-builder.json5",
    "build:beta": "tsc && vite build && electron-builder --config electron-builder.beta.json5",
    "release": "tsc && vite build && electron-builder --config electron-builder.json5 --publish always",
    "release:beta": "tsc && vite build && electron-builder --config electron-builder.beta.json5 --publish always",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "clsx": "^2.1.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.6.2",
    "framer-motion": "^11.15.0",
    "https": "^1.0.0",
    "lucide-react": "^0.468.0",
    "node-fetch": "^3.3.2",
    "ps-node": "^0.1.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.9.3",
    "set-interval-async": "^3.0.3",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^2.5.5",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.0.17",
    "autoprefixer": "^10.4.20",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^27.4.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^4.0.17"
  },
  "main": "dist-electron/app.js"
}
